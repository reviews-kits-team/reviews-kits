{
  "name": "reviews-kits",
  "private": true,
  "type": "module",
  "packageManager": "bun@1.0.0",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "build": "turbo build",
    "dev": "turbo dev",
    "lint": "turbo lint",
    "test": "turbo test",
    "prepare": "husky",
    "db:start": "docker compose --env-file .env -f infra/docker-compose.dev.yml up -d",
    "db:stop": "docker compose -f infra/docker-compose.dev.yml down",
    "db:reset": "docker compose -f infra/docker-compose.dev.yml down -v && bun run db:start && sleep 3 && cd apps/server && bun run db:push && bun run db:seed:admin"
  },
  "devDependencies": {
    "@types/bun": "latest",
    "husky": "^9.1.7",
    "turbo": "^2.8.20",
    "typescript": "^5.9.3"
  }
}
