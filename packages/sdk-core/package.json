{
  "name": "@reviewskits/core",
  "version": "0.0.1",
  "description": "The framework-agnostic core logic for ReviewsKits SDKs",
  "keywords": [
    "reviewskits",
    "sdk",
    "core",
    "reviews"
  ],
  "homepage": "https://reviewskits.com",
  "repository": {
    "type": "git",
    "url": "https://github.com/reviews-kits-team/reviews-kits.git",
    "directory": "packages/sdk-core"
  },
  "type": "module",
  "sideEffects": false,
  "main": "dist/index.cjs",
  "module": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup src/index.ts --format cjs,esm --dts --clean",
    "dev": "tsup src/index.ts --format cjs,esm --dts --watch",
    "test": "vitest --run --passWithNoTests",
    "test:watch": "vitest --passWithNoTests"
  },
  "devDependencies": {
    "@reviewskits/types": "^0.0.4",
    "tsup": "^8.3.5",
    "typescript": "^5.2.2",
    "vitest": "^4.1.2"
  }
}
