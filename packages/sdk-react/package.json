{
  "name": "@reviewskits/react",
  "version": "0.0.2",
  "description": "The official React SDK for ReviewsKits",
  "keywords": [
    "reviewskits",
    "testimonials",
    "react",
    "sdk",
    "reviews"
  ],
  "homepage": "https://reviewskits.com",
  "repository": {
    "type": "git",
    "url": "https://github.com/reviews-kits-team/reviews-kits.git",
    "directory": "packages/sdk-react"
  },
  "bugs": {
    "url": "https://github.com/reviews-kits-team/reviews-kits/issues"
  },
  "type": "module",
  "sideEffects": false,
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup src/index.ts --format cjs,esm --dts --clean",
    "dev": "tsup src/index.ts --format cjs,esm --dts --watch",
    "lint": "tsc --noEmit",
    "test": "vitest --run",
    "test:watch": "vitest"
  },
  "license": "MIT",
  "peerDependencies": {
    "react": ">=18"
  },
  "devDependencies": {
    "@reviewskits/types": "^0.0.4",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/react": "^19.0.0",
    "@vitejs/plugin-react": "^6.0.1",
    "jsdom": "^29.0.1",
    "react": "^19.0.0",
    "tsup": "^8.3.5",
    "typescript": "^5.9.3",
    "vitest": "^4.1.2"
  }
}
