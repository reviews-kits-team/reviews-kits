{
  "name": "@reviewskits/vue",
  "version": "0.0.1",
  "description": "Vue SDK for Reviewskits",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup src/index.ts --format cjs,esm --dts --clean",
