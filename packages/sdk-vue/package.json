{
  "name": "@reviewskits/vue",
  "version": "0.0.1",
  "description": "Official Vue 3 SDK for Reviewskits",
  "type": "module",
  "main": "dist/index.cjs",
  "module": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup src/index.ts --format cjs,esm --dts --clean",
    "dev": "tsup src/index.ts --format cjs,esm --dts --watch",
    "test": "vitest --run",
    "test:watch": "vitest"
  },
  "peerDependencies": {
    "vue": "^3.3.0"
  },
  "devDependencies": {
    "@reviewskits/types": "workspace:*",
    "@vue/test-utils": "^2.4.3",
    "happy-dom": "^12.10.3",
    "msw": "^2.0.11",
    "tsup": "^8.3.5",
    "typescript": "^5.2.2",
    "vitest": "^1.0.4",
    "vue": "^3.3.11"
  }
}
