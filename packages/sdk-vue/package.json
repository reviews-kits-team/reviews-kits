{
  "name": "@reviewskits/vue",
  "version": "0.0.2",
  "description": "The official Vue 3 SDK for ReviewsKits",
  "keywords": [
    "reviewskits",
    "testimonials",
    "vue",
    "nuxt",
    "sdk",
    "reviews"
  ],
  "homepage": "https://reviewskits.com",
  "repository": {
    "type": "git",
    "url": "https://github.com/reviews-kits-team/reviews-kits.git",
    "directory": "packages/sdk-vue"
  },
  "bugs": {
    "url": "https://github.com/reviews-kits-team/reviews-kits/issues"
  },
  "type": "module",
  "sideEffects": false,
  "main": "dist/index.cjs",
  "module": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup src/index.ts --format cjs,esm --dts --clean",
    "dev": "tsup src/index.ts --format cjs,esm --dts --watch",
    "test": "bun test",
    "test:watch": "bun test --watch"
  },
  "peerDependencies": {
    "vue": "^3.3.0"
  },
  "dependencies": {
    "@reviewskits/core": "workspace:*"
  },
  "devDependencies": {
    "@happy-dom/global-registrator": "^20.8.9",
    "@reviewskits/types": "^0.0.4",
    "@vue/test-utils": "^2.4.3",
    "happy-dom": "^20.0.0",
    "msw": "^2.0.11",
    "tsup": "^8.3.5",
    "typescript": "^5.2.2",
    "vue": "^3.3.11"
  }
}